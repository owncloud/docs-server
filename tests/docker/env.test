# Test environment — copied as .env alongside docker-compose.yml by run-tests.sh
OWNCLOUD_IMAGE=11.0.0-prealpha
OWNCLOUD_DOMAIN=localhost
OWNCLOUD_TRUSTED_DOMAINS=localhost
OWNCLOUD_OVERWRITE_CLI_URL=http://localhost
HTTP_PORT=8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
MARIADB_IMAGE=10.11
REDIS_IMAGE=7

# Security note: the docker-compose.yml exposes MariaDB (3306) and Redis (6379)
# on 0.0.0.0 by default. In a CI environment this is acceptable; on a local
# developer machine these ports are reachable from the local network for the
# duration of the test run. No credentials in this file are production values.
